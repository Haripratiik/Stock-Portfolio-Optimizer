# =============================================================================
#  PortfolioManagement — API Secrets  (EXAMPLE — safe to commit)
#  Copy this file to ".env" and fill in your real keys.
#  The actual ".env" file is git-ignored.
# =============================================================================

# OpenAI  →  https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# OPENAI_REQUEST_DELAY_SECONDS=22  # Seconds between API calls (22 for 3 RPM free tier; lower if paid)

# Finnhub  →  https://finnhub.io/register
FINNHUB_KEY=your_finnhub_key_here

# NewsAPI  →  https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# Alpha Vantage  →  https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_KEY=your_alphavantage_key_here

# Alpaca (paper trading)  →  https://app.alpaca.markets/signup
# Uses alpaca-py SDK (pip install alpaca-py)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Firestore rules — your Google sign-in email (only this user can access the app)
# Required for: node scripts/generate-firestore-rules.js  (run before firebase deploy)
OWNER_EMAIL=your-email@gmail.com

# Pipeline toggles (optional)
# USE_STOP_LOSS=false           # Disable per-trade stop-loss
# USE_WALK_FORWARD=false        # Disable walk-forward validation (incremental runs only)
# USE_EARNINGS_BLACKOUT=false   # Disable earnings proximity sizing (default: true)
# USE_REGIME_DETECTION=false    # Disable regime-based size/conf overrides (default: true)
# USE_CORRELATION_ADJUSTMENT=false # Disable correlation-aware position scaling (default: true)
